rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -- Colección de PDA --
    // Cualquier usuario autenticado (anónimo incluido) puede leer y
    // modificar cualquier terminal. Borrar está prohibido: los terminales
    // solo se marcan como "No localizada", nunca se eliminan de la base.
    match /pdas/{codigo} {
      allow read, update: if request.auth != null;
      allow create: if request.auth != null
                    && exists(/databases/$(database)/documents/meta/estado_inicial);
      allow delete: if false;
    }

    // -- Documento de siembra inicial --
    // Solo se puede crear una vez (cuando no existe todavía). Nadie puede
    // sobreescribirlo ni borrarlo: es el "candado" que impide que dos PCs
    // siembren las 160 PDA al mismo tiempo si abren la app por primera vez
    // en paralelo (ver store.js:inicializarSiVacio).
    match /meta/estado_inicial {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && !exists(/databases/$(database)/documents/meta/estado_inicial);
      allow update, delete: if false;
    }
  }
}
